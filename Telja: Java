import java.util.Scanner;

public class telja {
    public static void main (String args[]) {
        int n = new Scanner(System.in).nextInt ();
        
        int out = 1;
      // although "while (n--)" would work in C-like languages, Java doesn't allow this kind of implicit conversion
        while (n-- > 0) {
            System.out.println (out++);
        }
    }
}
